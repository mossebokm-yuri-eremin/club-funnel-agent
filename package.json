{
  "name": "club-funnel-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Контент-агент Юрия Еремина — воронка в клуб «Реализация» (RZ).",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:up": "tsx scripts/migrate.ts up",
    "migrate:down": "tsx scripts/migrate.ts down",
    "seed:voices": "tsx scripts/seed-voices.ts",
    "seed:bonus": "tsx scripts/seed-bonus-library.ts",
    "seed:bonus:dry": "tsx scripts/seed-bonus-library.ts --dry-run",
    "refresh:brain": "tsx scripts/refresh-brain.ts",
    "pdf:render": "tsx scripts/pdf-render.ts",
    "reports:weekly": "tsx scripts/reports-weekly.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "bullmq": "^5.34.0",
    "cloudinary": "^2.5.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "grammy": "^1.32.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "sharp": "^0.33.5",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "sharp"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
