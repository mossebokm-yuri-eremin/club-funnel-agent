<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <title>{{title}}</title>
    <style>
      @page { size: A4; margin: 24mm 22mm; }
      body { font-family: -apple-system, "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
             font-size: 12pt; line-height: 1.55; color: #1b1b1b; }
      h1 { font-size: 24pt; margin: 0 0 0.4em; }
      h2 { font-size: 16pt; margin: 1.8em 0 0.4em; }
      h3 { font-size: 13pt; margin: 1.4em 0 0.3em; }
      blockquote { border-left: 3px solid #c8a96a; padding: 0.2em 1em;
                   color: #444; background: #fbf7ef; margin: 1em 0; }
      .meta { color: #888; font-size: 10pt; margin-bottom: 1.4em; }
      .footer { color: #999; font-size: 9pt; margin-top: 2em; border-top: 1px solid #eee;
                padding-top: 0.6em; }
    </style>
  </head>
  <body>
    <h1>{{title}}</h1>
    <div class="meta">{{painTag}} · {{wordCount}} слов · {{date}}</div>
    {{{bodyHtml}}}
    <div class="footer">Клуб «Реализация» — yury-eremin.tld · {{codeWord}}</div>
  </body>
</html>
