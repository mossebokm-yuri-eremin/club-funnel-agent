# =============================================================================
# club-funnel-agent — .env.example
# Копировать в .env (chmod 600), копию класть в Bitwarden коллекцию
# «MOSSEBO Production». В git .env НИКОГДА не коммитим.
# =============================================================================

# -----------------------------------------------------------------------------
# Окружение
# -----------------------------------------------------------------------------
NODE_ENV=production                    # development | production
APP_NAME=club-funnel-agent
APP_HOST=0.0.0.0
APP_PORT=3000
APP_PUBLIC_BASE_URL=https://agent.yury-eremin.tld   # для webhook URL и QR
TZ=Europe/Moscow

# -----------------------------------------------------------------------------
# PostgreSQL (Beget VPS, локально)
# -----------------------------------------------------------------------------
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=club_funnel
PG_USER=app_runtime
PG_PASSWORD=changeme-strong-runtime-password
PG_SSL=false                           # для локального соединения - false; для удалённого - true
PG_POOL_MAX=20

# Отдельные креды супер-роли для миграций (только в pipeline, не в рантайме)
PG_DBA_USER=admin_dba
PG_DBA_PASSWORD=changeme-strong-dba-password

# -----------------------------------------------------------------------------
# Redis (BullMQ)
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                        # пустое если без auth
REDIS_DB=0

# -----------------------------------------------------------------------------
# Anthropic (Claude)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL_GENERATIVE=claude-sonnet-4-6              # генерация контента
ANTHROPIC_MODEL_THINKING=claude-opus-4-7                  # лонгриды, AUDIENCE BRAIN, REFERENCE ADAPTER, weekly
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001            # категоризация, voice validator
ANTHROPIC_THINKING_BUDGET_TOKENS=32000

# -----------------------------------------------------------------------------
# Google AI (Gemini 2.5 Pro Video + Nano Banana Pro / Gemini 3 Pro Image)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_VIDEO_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=gemini-3-pro-image

# -----------------------------------------------------------------------------
# Deepgram STT
# -----------------------------------------------------------------------------
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=ru

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=gptunnel            # gptunnel (default, оплата ₽) | openai | anthropic (TBD)
OPENAI_API_KEY=                        # опц. — нужен только для fallback или EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
GPTUNNEL_EMBEDDING_BASE_URL=https://gptunnel.ru/v1
GPTUNNEL_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_OPENAI_FALLBACK=true         # если GPTunnel упал и есть OPENAI_API_KEY — пробуем OpenAI

# -----------------------------------------------------------------------------
# Telegram (grammY)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=1234567890:AA-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_USERNAME=yury_eremin_bot
YE_TG_USER_ID=123456789                # tg_user_id Юрия (только он принимает команды)
ANNA_TG_CHAT_ID=-1001234567890         # чат с Анной для публикаций
TG_WEBHOOK_SECRET=changeme-tg-webhook-secret

# -----------------------------------------------------------------------------
# Instagram Graph API v25.0
# -----------------------------------------------------------------------------
IG_USER_ID=17841401234567890
IG_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx        # long-lived, обновляем cron'ом
IG_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
IG_WEBHOOK_VERIFY_TOKEN=changeme-ig-verify-token        # для GET /webhook/instagram
YE_IG_USERNAME=yury_eremin
IG_COOKIES_PATH=/var/lib/ytdlp/cookies.txt              # для yt-dlp на приватных постах

# -----------------------------------------------------------------------------
# ChatPlace API
# -----------------------------------------------------------------------------
CHATPLACE_API_BASE=https://api.chatplace.io/v1
CHATPLACE_API_KEY=cp_live_xxxxxxxxxxxxxxxxxxxxxxxx
CHATPLACE_WEBHOOK_TOKEN=changeme-chatplace-bearer

# -----------------------------------------------------------------------------
# GetCourse
# -----------------------------------------------------------------------------
GC_ACCOUNT=mossebo                                       # mossebo.getcourse.ru
GC_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GC_WEBHOOK_SECRET=changeme-getcourse-hmac-secret         # HMAC SHA-256
GC_BASE_OFFER_ID=789                                     # ЕДИНСТВЕННЫЙ оффер — клуб «Реализация» (CLAUDE.md §1 sacred)
GC_BASE_PRICE_KOPECKS=500000                             # 5000.00 ₽
GC_API_BASE=https://account.getcourse.ru/pl/api          # перекрыть для теста
GC_PULL_PAGE_SIZE=100                                    # размер страницы для hourly pull

# -----------------------------------------------------------------------------
# Cloudinary
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=mossebo
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDINARY_UPLOAD_FOLDER=club-funnel
CLOUDINARY_FALLBACK_LOCAL_DIR=/var/www/cdn               # если Cloudinary down

# -----------------------------------------------------------------------------
# Google Drive (service account JSON)
# -----------------------------------------------------------------------------
GDRIVE_SERVICE_ACCOUNT_JSON_PATH=/etc/club-funnel/gdrive-sa.json
GDRIVE_LONGREADS_FOLDER_ID=1Abc...XyzZ                   # «MOSSEBO / Реализация / Лонгриды»
GDRIVE_CAROUSEL_TEMPLATES_FOLDER_ID=1Bcd...AbcD          # «MOSSEBO / Шаблоны каруселей» — папка с cover.svg / body.svg / cta.svg, расшаренная на client_email сервис-аккаунта (Viewer достаточно)
CAROUSEL_TEMPLATES_TTL_S=300                             # TTL кэша SVG-шаблонов (сек). /refresh_templates сбрасывает вручную.
GDRIVE_YE_PHOTO_FILE_ID=1Efg...HijK                      # фото Юрия для обложек PDF

# -----------------------------------------------------------------------------
# RapidAPI (yt-dlp fallback)
# -----------------------------------------------------------------------------
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAPIDAPI_IG_HOST=instagram-downloader.p.rapidapi.com

# -----------------------------------------------------------------------------
# GitHub (для AUDIENCE BRAIN — чтение /knowledge/)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_KNOWLEDGE_REPO=yury-eremin/wiki                   # owner/repo
GITHUB_KNOWLEDGE_BRANCH=main
GITHUB_KNOWLEDGE_PATH=knowledge                          # папка внутри репо

# -----------------------------------------------------------------------------
# Файловое хранилище и пути
# -----------------------------------------------------------------------------
DATA_DIR=/mnt/data                                       # корень для рантайм-файлов
REFS_DIR=/mnt/data/refs                                  # скачанные референсы
PDF_TMP_DIR=/mnt/data/tmp/pdf                            # временные рендеры лонгридов

# -----------------------------------------------------------------------------
# Лимиты и пороги
# -----------------------------------------------------------------------------
VOICE_VALIDATOR_MIN_DENSITY=0.3                          # маркеры/100 слов
VOICE_VALIDATOR_MAX_RETRIES=3
STRATEGY_A_MIN_SIMILARITY=0.85
STRATEGY_C_MAX_SIMILARITY=0.65
STRATEGY_B_PERIOD_IDEAS=10                               # каждые N идей — A/B тест
LONGREAD_MIN_WORDS=1500
LONGREAD_MAX_WORDS=2500
BONUS_CR_DROP_THRESHOLD_PCT=30                           # % — порог алерта
WARMUP_LONG_TAIL_WEEKS=8                                 # длинный прогрев
INFERENCE_BUDGET_TOKENS_DAILY=8000000                    # для алерта на расход

# -----------------------------------------------------------------------------
# Логи и наблюдаемость
# -----------------------------------------------------------------------------
LOG_LEVEL=info                                            # trace|debug|info|warn|error|fatal
LOG_PRETTY=false                                          # true в dev
LOG_REDACT_PD=true
PROMETHEUS_PORT=9090
LOKI_ENDPOINT=                                            # пусто = не отправляем

# -----------------------------------------------------------------------------
# Cron-расписания (в формате node-cron)
# -----------------------------------------------------------------------------
CRON_GC_RECONCILE='0 * * * *'                             # каждый час
CRON_BONUS_CR_AUDIT='15 3 * * *'                          # 03:15 daily
CRON_REFS_CROSSCHECK='30 4 * * *'                         # 04:30 daily — сравнение референсов с winning_patterns
CRON_WEEKLY_REPORT='0 10 * * 6'                           # сб 10:00
CRON_IG_TOKEN_REFRESH='0 2 1 * *'                         # 1 числа в 02:00
CRON_REFERENCES_NUDGE='0 9 * * *'                         # 09:00 daily — пуш о висящих референсах

# -----------------------------------------------------------------------------
# Отладочные флаги (only for dev/staging)
# -----------------------------------------------------------------------------
DEV_BYPASS_VOICE_VALIDATOR=false                          # никогда true в проде
DEV_DRY_RUN_CHATPLACE=false                               # не создаёт реальные автоматизации
DEV_DRY_RUN_GETCOURSE=false                               # не отправляет реальные офферы

# --- Club (post-payment auto-invite) ---
CLUB_TG_INVITE_URL=https://t.me/+ABCDEFGHIJK_invite_link_here
CLUB_TG_GROUP_NAME=Реализация
